# Supabase — contact form (client-side, public anon key)
# Copy this file to .env.local and fill in your real values from
# Supabase Dashboard → Project Settings → API.
#
# These are PUBLIC values (safe to expose in the browser). The anon key only
# has the permissions your Row-Level-Security policies allow — see SUPABASE_SETUP.md.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
